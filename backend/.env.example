# Backend Configuration
HOST=0.0.0.0
PORT=8000

# Ollama LLM Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest

# CORS Configuration
CORS_ORIGINS=["https://dev-assistente.jucepi.pi.gov.br","http://localhost:5173","http://localhost:3000"]

# Logging Configuration
LOG_LEVEL=INFO

# RAG Configuration
RAG_TOP_K=3
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM Generation Configuration
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512
LLM_TIMEOUT=30
